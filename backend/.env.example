PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/subscriptionDB
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM=Subscription Overload Manager <your-email@gmail.com>
CLIENT_URL=http://localhost:5173
REMINDER_SWEEP_COOLDOWN_MINUTES=15
REMINDER_BATCH_SIZE=25
REMINDER_LOOKAHEAD_DAYS=30
REMINDER_GRACE_DAYS=14
REMINDER_CRON_SCHEDULE=0 9 * * *
REMINDER_CRON_TIMEZONE=Asia/Kolkata
